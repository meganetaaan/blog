---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeHeroImage from '../assets/kasane-workshop-home.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="section recent-posts">
				<div class="home-hero">
					<div>
						<p class="eyebrow">Recent Posts</p>
						<h1>最近の記録</h1>
						<p class="lead">
							新しく試したこと、設計で迷ったこと、運用して分かったことを記録しています。
							更新順に追えば、最近なにを考えていたかが分かります。
						</p>
					</div>
					<figure class="home-hero-visual">
						<Image
							width={1200}
							height={676}
							src={HomeHeroImage}
							alt="朝日の入る作業机で、かさねちゃんが Stack-chan と一緒にノートへ設計メモを書いている様子"
						/>
					</figure>
				</div>
				<div class="cards">
					{latestPosts.map((post) => (
						<a class="card" href={`${import.meta.env.BASE_URL}/${post.id}/`}>
							<p class="meta">{post.data.pubDate.toLocaleDateString('ja-JP')}</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="section note">
				<h2>このブログについて</h2>
				<ul>
					<li>新しいツールや構成を試したときの判断理由を残します</li>
					<li>うまくいかなかった点や運用上の摩擦も省かずに書きます</li>
					<li>あとから読み返して手がかりになる記録を目指します</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.recent-posts {
		padding-top: 5rem;
	}
	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
		gap: 2rem;
		align-items: center;
	}
	.home-hero-visual {
		margin: 0;
	}
	.home-hero-visual img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 28px;
		box-shadow: 0 20px 50px rgba(var(--gray), 0.18);
	}
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}
	.lead {
		font-size: 1.1rem;
		max-width: 42rem;
	}
	.section {
		margin-top: 3rem;
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}
	.card {
		display: block;
		padding: 1.2rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 12px 30px rgba(var(--gray), 0.14);
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 36px rgba(var(--gray), 0.18);
	}
	.card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.5rem;
	}
	.meta {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin-bottom: 0.6rem;
	}
	.note ul {
		padding-left: 1.2rem;
	}
	.note li {
		margin-bottom: 0.5rem;
	}
	@media (max-width: 760px) {
		.home-hero {
			grid-template-columns: 1fr;
		}
		.recent-posts {
			padding-top: 3rem;
		}
	}
</style>
