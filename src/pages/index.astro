---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR_NAME, AUTHOR_TAGLINE, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Author</p>
				<h1>{AUTHOR_NAME}</h1>
				<p class="tagline">{AUTHOR_TAGLINE}</p>
				<p class="lead">
					ここは、私が選んだ技術や設計の理由を、自分の言葉で残していく場所です。
					なにが扱いやすく、なにが長く保てるかを、そのまま書きます。
				</p>
			</section>

			<section class="section">
				<h2>最近の記録</h2>
				<div class="cards">
					{latestPosts.map((post) => (
						<a class="card" href={`/${post.id}/`}>
							<p class="meta">{post.data.pubDate.toLocaleDateString('ja-JP')}</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="section note">
				<h2>この場所について</h2>
				<ul>
					<li>TypeScript, React, Markdown を中心に考えます</li>
					<li>Astro と静的配信の相性を試しながら記録します</li>
					<li>判断理由, 運用のしやすさ, 保守性を重視します</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 5rem 0 3rem;
	}
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}
	.tagline {
		font-size: 1.2rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}
	.lead {
		font-size: 1.1rem;
		max-width: 42rem;
	}
	.section {
		margin-top: 3rem;
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}
	.card {
		display: block;
		padding: 1.2rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 12px 30px rgba(var(--gray), 0.14);
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 36px rgba(var(--gray), 0.18);
	}
	.card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.5rem;
	}
	.meta {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin-bottom: 0.6rem;
	}
	.note ul {
		padding-left: 1.2rem;
	}
	.note li {
		margin-bottom: 0.5rem;
	}
</style>
