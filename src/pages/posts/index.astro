---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { AUTHOR_NAME, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featuredPost, ...restPosts] = posts;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="eyebrow">Blog</p>
				<h1>記録の一覧</h1>
				<p>
					{AUTHOR_NAME} が、技術選定、設計メモ、小さな進捗を積み重ねていく場所です。
				</p>
			</section>

			{featuredPost && (
				<section class="featured">
					<a href={`/${featuredPost.id}/`}>
						{featuredPost.data.heroImage && (
							<Image width={1200} height={630} src={featuredPost.data.heroImage} alt="" />
						)}
						<div class="copy">
							<p class="eyebrow">Latest</p>
							<h2>{featuredPost.data.title}</h2>
							<p class="date"><FormattedDate date={featuredPost.data.pubDate} /></p>
							<p>{featuredPost.data.description}</p>
						</div>
					</a>
				</section>
			)}

			<section class="grid">
				{restPosts.map((post) => (
					<a class="card" href={`/${post.id}/`}>
						<h3>{post.data.title}</h3>
						<p class="date"><FormattedDate date={post.data.pubDate} /></p>
						<p>{post.data.description}</p>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding-top: 4rem;
		margin-bottom: 2rem;
	}
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.78rem;
		color: rgb(var(--gray));
	}
	.featured a {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: 1.5rem;
		align-items: center;
		text-decoration: none;
		color: inherit;
		padding: 1rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 18px 40px rgba(var(--gray), 0.15);
	}
	.featured img {
		width: 100%;
		margin: 0;
	}
	.featured h2 {
		font-size: 2rem;
		margin: 0.3rem 0 0.5rem;
	}
	.date {
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}
	.card {
		padding: 1.25rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 12px 30px rgba(var(--gray), 0.12);
		text-decoration: none;
		color: inherit;
	}
	.card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.4rem;
	}
	@media (max-width: 720px) {
		.featured a {
			grid-template-columns: 1fr;
		}
	}
</style>
